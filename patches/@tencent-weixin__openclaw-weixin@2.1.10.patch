+const MONITOR_START_STAGGER_MS = 750;
+let nextMonitorStartAt = 0;
+
+async function waitForMonitorStartSlot(): Promise<void> {
+  const now = Date.now();
+  const waitMs = Math.max(0, nextMonitorStartAt - now);
+  nextMonitorStartAt = now + waitMs + MONITOR_START_STAGGER_MS;
+  if (waitMs > 0) {
+    await new Promise((resolve) => setTimeout(resolve, waitMs));
+  }
+}
 
