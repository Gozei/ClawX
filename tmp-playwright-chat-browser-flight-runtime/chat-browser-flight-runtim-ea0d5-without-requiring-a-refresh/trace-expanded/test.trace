{"type":"before","callId":"pw:api@37","stepId":"pw:api@37","startTime":9935.181,"class":"Test","method":"pw:api","title":"Evaluate","params":{"expression":"({\n        ipcMain,\n        BrowserWindow\n      }, {\n        prompt,\n        sessionKey,\n        sessionId,\n        runId,\n        finalHeader,\n        finalRow\n      }) => {\n        let sessions = [];\n        let historyMessages = [];\n        function emitNotification(payload) {\n          const window = BrowserWindow.getAllWindows().at(-1);\n          if (!window) throw new Error('No BrowserWindow available');\n          window.webContents.send('gateway:notification', payload);\n        }\n        ipcMain.removeHandler('gateway:rpc');\n        ipcMain.handle('gateway:rpc', async (_event, method, params) => {\n          if (method === 'sessions.list') {\n            return {\n              sessions\n            };\n          }\n          if (method === 'chat.history') {\n            return {\n              messages: historyMessages\n            };\n          }\n          if (method === 'chat.abort') {\n            return {\n              ok: true\n            };\n          }\n          if (method === 'chat.send') {\n            const now = Date.now();\n            const activeSessionKey = (params === null || params === void 0 ? void 0 : params.sessionKey) || sessionKey;\n            const visiblePrompt = prompt;\n            sessions = [{\n              key: activeSessionKey,\n              id: sessionId,\n              label: visiblePrompt,\n              updatedAt: now\n            }];\n            historyMessages = [{\n              id: 'user-browser-flight-1',\n              role: 'user',\n              content: visiblePrompt,\n              timestamp: Math.floor(now / 1000)\n            }];\n            setTimeout(() => {\n              emitNotification({\n                method: 'agent',\n                params: {\n                  phase: 'started',\n                  runId,\n                